# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# China A-share data sources
TUSHARE_TOKEN=
OPENNEWS_TOKEN=
OPENNEWS_API_BASE=https://ai.6551.io
OPENNEWS_WSS_URL=wss://ai.6551.io/open/news_wss
# Optional: only set this if you run an OpenNews MCP server with streamable HTTP transport.
OPENNEWS_MCP_URL=
JIN10_MCP_TOKEN=
JIN10_MCP_URL=https://mcp.jin10.com/mcp

# Optional iFinD QuantAPI enrichment.
# Access token is used first; refresh token is used to mint/refresh access tokens.
IFIND_ENABLED=true
IFIND_API_BASE=https://quantapi.51ifind.com/api/v1
IFIND_ACCESS_TOKEN=
IFIND_REFRESH_TOKEN=
IFIND_TIMEOUT_SECONDS=20

# Optional local browser-session forum monitoring
SOCIAL_MONITOR_ENABLED=true
SOCIAL_BROWSER_PROFILE_DIR=~/.tradingagents/social_browser
SOCIAL_MONITOR_SOURCES=eastmoney_guba
SOCIAL_MONITOR_INTERVAL_SECONDS=300
SOCIAL_MONITOR_MAX_POSTS_PER_SYMBOL=200
SOCIAL_MONITOR_MAX_PAGES=3
SOCIAL_EASTMONEY_PAGE_SETTLE_MS=1200
SOCIAL_EASTMONEY_ENABLE_SCROLL=false
